# URL de base de l'API FastAPI (sans slash final)
VITE_API_BASE_URL=https://api.example.com

# Username du bot Telegram (sans @), utilisé pour les liens de parrainage t.me/<bot>?start=...
VITE_BOT_USERNAME=club_jm_bot

# Lien d'invitation du canal Telegram requis (force-sub)
VITE_CHANNEL_URL=https://t.me/+exemple_canal

# Nom affiché du canal (optionnel)
VITE_CHANNEL_NAME=CLUB JM Officiel
